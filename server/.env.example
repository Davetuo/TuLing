# 服务端口
PORT=3000

# 数据库
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tuling?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT（请替换为实际密钥）
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS（允许的跨域来源，逗号分隔）
CORS_ORIGINS=http://localhost:5173

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@tuling.app

# ─── LLM Provider（OpenAI 兼容接口）───
# 支持所有兼容 OpenAI Chat Completions API 的服务：
#   - OpenAI:       https://api.openai.com
#   - DeepSeek:     https://api.deepseek.com
#   - 通义千问:      https://dashscope.aliyuncs.com/compatible-mode
#   - 智谱 GLM:     https://open.bigmodel.cn/api/paas
#   - Moonshot:     https://api.moonshot.cn
#   - Ollama 本地:   http://localhost:11434
#   - LM Studio:    http://localhost:1234

# API 基础地址（必填，不含 /v1/chat/completions 后缀）
LLM_API_URL=https://api.openai.com

# API 密钥（必填，Bearer Token 认证）
LLM_API_KEY=sk-your-api-key-here

# 模型名称（选填，默认 gpt-3.5-turbo）
# 常见模型：
#   OpenAI:    gpt-4o / gpt-4o-mini / gpt-3.5-turbo
#   DeepSeek:  deepseek-chat / deepseek-reasoner
#   通义千问:   qwen-plus / qwen-turbo / qwen-max
#   智谱 GLM:  glm-4-flash / glm-4
#   Moonshot:  moonshot-v1-8k / moonshot-v1-32k
#   Ollama:    llama3 / qwen2 / mistral
LLM_MODEL=gpt-3.5-turbo
